# ─────────────────────────────────────────────────────────────────────────────
# Environment — "local" (TinyDB + ChromaDB) or "prod" (MongoDB + pgvector)
# ─────────────────────────────────────────────────────────────────────────────
ENV=local

# Telemetry — false locally (console logs only), set true in Railway dashboard
# When true, ChromaDB and other instrumented libs send anonymised usage data.
ANONYMIZED_TELEMETRY=false

# ─────────────────────────────────────────────────────────────────────────────
# LLM — get a free key at https://aistudio.google.com
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings (local model — no API key needed)
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# Storage — Local (used when ENV=local)
# ─────────────────────────────────────────────────────────────────────────────
ARTICLES_DB_PATH=app/data/articles.json
CHROMA_PERSIST_DIR=app/data/chroma
CHROMA_COLLECTION_NAME=insurance_articles

# ─────────────────────────────────────────────────────────────────────────────
# Storage — Production / Railway (used when ENV=prod)
# Set these when deploying to Railway. Leave blank for local development.
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>
DATABASE_URL=postgresql://<user>:<pass>@<host>:<port>/<dbname>
PGVECTOR_TABLE=chunks

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Guardrails — false bypasses all checks (useful for dev/testing)
# ─────────────────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# RAG pipeline
# ─────────────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ─────────────────────────────────────────────────────────────────────────────
# LLM behaviour — tune retries and creativity
# ─────────────────────────────────────────────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2
LLM_RETRY_AFTER_SECONDS=10

# ─────────────────────────────────────────────────────────────────────────────
# Session — lifetime in seconds (default 2 hours)
# ─────────────────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=7200

# ─────────────────────────────────────────────────────────────────────────────
# Search — pagination and retrieval tuning
# ─────────────────────────────────────────────────────────────────────────────
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50
SEARCH_QUERY_MAX_LEN=200
SEARCH_SNIPPET_MAX_LEN=200
SEARCH_KEYWORD_BOOST=0.15

# ─────────────────────────────────────────────────────────────────────────────
# Chat — maximum characters per user message
# ─────────────────────────────────────────────────────────────────────────────
CHAT_MESSAGE_MAX_LEN=2000

# ─────────────────────────────────────────────────────────────────────────────
# Articles — pagination defaults and related article count
# ─────────────────────────────────────────────────────────────────────────────
ARTICLE_DEFAULT_LIMIT=20
ARTICLE_MAX_LIMIT=100
ARTICLE_RELATED_LIMIT=3
