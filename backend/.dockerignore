# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environment
venv/
.venv/
env/

# Environment secrets — never bake into image
.env
.env.*
!.env.example

# Dev/test artifacts
tests/
scripts/
*.log

# Local vector store — never bake ChromaDB data into the image
app/data/chroma/

# Raw scrape output — not needed at runtime
app/data/articles_raw.json

# Docs and markdown — not needed in runtime image
docs/
*.md

# OS
.DS_Store
